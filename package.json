{
  "name": "claude-explorer",
  "version": "0.0.3",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "set \"NODE_OPTIONS=--experimental-require-module\" && vitest run",
    "package": "electron-vite build && set \"NODE_OPTIONS=--experimental-require-module\" && electron-builder --win",
    "release": "electron-vite build && set \"NODE_OPTIONS=--experimental-require-module\" && electron-builder --win --publish always"
  },
  "keywords": [
    "claude",
    "claude-code",
    "electron",
    "file-manager",
    "windows"
  ],
  "author": "Claude Explorer contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/danmano411/claude-explorer.git"
  },
  "description": "Browse folders, open Claude Code in an embedded terminal",
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "build": {
    "appId": "com.danma.claude-explorer",
    "productName": "Claude Explorer",
    "npmRebuild": false,
    "publish": [
      { "provider": "github", "owner": "danmano411", "repo": "claude-explorer" }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Explorer"
    },
    "icon": "img/icon.png",
    "extraResources": [
      {
        "from": "img/icon.png",
        "to": "icon.png"
      }
    ]
  }
}
